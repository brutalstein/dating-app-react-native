# Environment Configuration for Production Deployment
# Copy this file to .env and fill in your production values
# NEVER commit the actual .env file with secrets!

# ===========================================
# Database Configuration
# ===========================================
DB_PASSWORD=ChangeThisToASecurePassword123!

# ===========================================
# JWT Security - CRITICAL FOR PRODUCTION
# ===========================================
# Generate a strong random secret: openssl rand -base64 64
# Example: openssl rand -base64 64
JWT_SECRET=ChangeThisToASecureRandomSecretInProductionMinimum32CharactersLong

# Token expiration times (in milliseconds)
# Access token: 1 hour (3600000 ms) - shorter is more secure
JWT_EXPIRATION_MS=3600000
# Refresh token: 7 days (604800000 ms)
JWT_REFRESH_EXPIRATION_MS=604800000

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins for production
# Example: https://yourdomain.com,https://app.yourdomain.com
# Leave empty for development (localhost only)
CORS_ALLOWED_ORIGINS=

# ===========================================
# Email/SMTP Configuration (for verification emails)
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ===========================================
# Push Notification Configuration
# ===========================================
PUSH_ENABLED=true

# Firebase Cloud Messaging (Android)
FCM_SERVER_KEY=your-fcm-server-key

# Apple Push Notification Service (iOS)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_BUNDLE_ID=com.yourcompany.bloom
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
APNS_SANDBOX=false

# ===========================================
# Rate Limiting Configuration
# ===========================================
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LIMIT=12
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_CRITICAL_LIMIT=40
RATE_LIMIT_CRITICAL_WINDOW_SECONDS=60
RATE_LIMIT_EXPLORE_HUB_LIMIT=480
RATE_LIMIT_EXPLORE_HUB_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_FAILURE_THRESHOLD=5
RATE_LIMIT_AUTH_FAILURE_BASE_BLOCK_SECONDS=30
RATE_LIMIT_AUTH_FAILURE_MAX_BLOCK_SECONDS=900
RATE_LIMIT_MESSAGE_FLOOD_LIMIT=15
RATE_LIMIT_MESSAGE_FLOOD_WINDOW_SECONDS=20

# ===========================================
# Frontend Configuration
# ===========================================
# Production API URL - update this to your actual domain
EXPO_PUBLIC_API_BASE_URL=https://your-api-domain.com/api

# ===========================================
# Spring Boot Configuration
# ===========================================
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
JPA_SHOW_SQL=false
FLYWAY_VALIDATE_ON_MIGRATE=true
FLYWAY_VALIDATE_MIGRATION_NAMING=true
FLYWAY_OUT_OF_ORDER=false
FLYWAY_CLEAN_DISABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false

# ===========================================
# Feature Flags
# ===========================================
DUMMY_SIMULATION_ENABLED=false
BLOOM_DUMMY_CHAT_ENABLED=false
